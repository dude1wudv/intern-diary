<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="6dp">

    <TextView
        android:id="@+id/textBody"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginStart="56dp"
        android:background="@drawable/bg_bubble_user"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:textColor="?attr/bubbleUserTextColor"
        android:textIsSelectable="true"
        android:textSize="16sp"
        tools:text="帮我把今天的日记语气改得更正式一点" />

    <TextView
        android:id="@+id/textTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="3dp"
        android:layout_marginEnd="4dp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="11sp"
        tools:text="14:20" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="2dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnCopyMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingEnd="14dp"
            android:text="@string/action_copy"
            android:textColor="?attr/colorPrimary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/btnDeleteMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/assistant_delete"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
